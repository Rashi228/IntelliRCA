FROM python:3.11-slim

WORKDIR /app

# Install dependencies required for Gateway
COPY requirements.txt .
RUN pip install --no-cache-dir fastapi uvicorn structlog httpx websockets prometheus-client

COPY . .

# Expose the single gateway port
EXPOSE 8080

CMD ["uvicorn", "app.gateway.main:app", "--host", "0.0.0.0", "--port", "8080"]
